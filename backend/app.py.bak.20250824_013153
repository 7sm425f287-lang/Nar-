import os
import requests
from fastapi import FastAPI, Request
from fastapi.middleware.cors import CORSMiddleware

# ENV
LLM_TARGET = os.getenv("NIRO_LLM", "openai")  # "openai" oder "lmstudio"
OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
OPENAI_ORG_ID = os.getenv("OPENAI_ORG_ID")
OPENAI_PROJECT_ID = os.getenv("OPENAI_PROJECT_ID")

app = FastAPI()
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"], allow_methods=["*"], allow_headers=["*"]
)

@app.get("/health")
def health():
    return {"status": "ok", "llm": LLM_TARGET}

@app.post("/chat")
async def chat(request: Request):
    body = await request.json()
    user_message = (body.get("message") or "").strip()
    if not user_message:
        return {"reply": "Leere Nachricht."}

    try:
        if LLM_TARGET == "openai":
            if not OPENAI_API_KEY:
                return {"reply": "OPENAI_API_KEY fehlt."}
            headers = {"Authorization": f"Bearer {OPENAI_API_KEY}"}
            if OPENAI_ORG_ID:
                headers["OpenAI-Organization"] = OPENAI_ORG_ID
            if OPENAI_PROJECT_ID:
                headers["OpenAI-Project"] = OPENAI_PROJECT_ID

            r = requests.post(
                "https://api.openai.com/v1/chat/completions",
                headers=headers,
                json={
                    "model": "gpt-4o-mini",
                    "messages": [{"role": "user", "content": user_message}],
                    "temperature": 0.7,
                    "max_tokens": 512
                },
                timeout=60
            )
            r.raise_for_status()
            data = r.json()
            return {"reply": data["choices"][0]["message"]["content"]}

        elif LLM_TARGET == "lmstudio":
            r = requests.post(
                "http://localhost:1234/v1/chat/completions",
                json={
                    "messages": [{"role": "user", "content": user_message}],
                    "temperature": 0.7,
                    "max_tokens": 512
                },
                timeout=120
            )
            r.raise_for_status()
            data = r.json()
            return {"reply": data["choices"][0]["message"]["content"]}

        return {"reply": f"Unknown LLM target: {LLM_TARGET}"}

    except Exception as e:
        return {"reply": f"(Fallback) Echo: {user_message} | Hinweis: {e}"}
